# Path the frontend calls. In dev this is proxied to VITE_API_PROXY_TARGET
# (see vite.config.ts) to avoid CORS. In production set this to the full API URL
# of a backend that allows your deployed origin.
VITE_API_BASE_URL="/api"

# Dev-only: real backend origin the /api path is proxied to.
VITE_API_PROXY_TARGET="https://admin-moderator-backend-staging.up.railway.app"
